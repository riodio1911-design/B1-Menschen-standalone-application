{
  "57e76d778693c0d929352890c0e363e60d3f59c083b86a37015c6e449960350d": "die Beratung",
  "a092446605a973bcd4859b0e30a46510d90df3eeece9f96ecb6294a1606b7bdf": "Die Beratung im Geschäft war sehr hilfreich.",
  "69b5d0a8a01ff38c4c92f227e7e29291ca3cf82c5631bdfd6dba37152e9b2e19": "Es ist unsere Pflicht, das Tier zu pflegen.",
  "78593b08d28a76ef9a87f756a6d1f8c74178fe7829bf766c727f0fb380d21554": "Ich brauche deinen Rat.",
  "6b5e52259e79b650476d45791bac2873e2e0b8fb75ec80595a4deda7ecac6d80": "Der Hund braucht viel Bewegung.",
  "49971ec3841007ce90c1d6f6df6197b51009c52ccd0e713192da2d1eb9a194a3": "Kaninchen fressen gerne Möhren.",
  "eaf1d39a221fa42560fb8d3b7e38795c8aaf6a027ee37374517754a46904772b": "Ich möchte mir einen Hund anschaffen.",
  "7b2cbc3972844d4b7e4a17a3f1c55f0476a14623d2461bfe9642dbd9b4bd07ac": "Sie sollten berücksichtigen, dass...",
  "26a1d8f867513bd9517dd2dff5838a70508d5246075104f5843593bc857d8747": "Ich habe mich schon entschieden.",
  "2ed37fbbf8cbdc9a83db445df6b8f8fef4caf3b969a7dd341f958580156360d9": "Man muss mit hohen Kosten rechnen.",
  "cb7116a5ebe5376fc01f0cdccfaef94898e41b5b12616ab966c02db57126adcd": "ausgeben (Geld)",
  "ce6290f601079beeaa8494c660197c620dc9bd024f17286925534340506c4a04": "Er gibt viel Geld aus.",
  "50a11d8a113b5865f6b46505d1363d42506ee634118ede1c32a143f0d1ce2936": "pflegen",
  "f4dd68547db53b7f9f534e36195a4de86902e62222763ffb7522272be4315f7e": "Man muss das Tier pflegen.",
  "7374e3486a89d1232ef96f920b0ac694ab91ee4e6d2c6c720a540b31b4e1283b": "Ich muss mit dem Hund rausgehen.",
  "8024bbc442a2dc2fec1a9294a40abd5605a67fb6b53284c573330e6c727921bc": "Tagsüber bin ich bei der Arbeit.",
  "41122fd85fda233369ee60b2250449bc958bbbd5e02ecff87dc6bb9899991a7a": "Er taucht gerne im Meer.",
  "82c3a9a4aa2b4f1f0445d7caace51976761680e63fcde6ea4bf6256fb27340e3": "momentan",
  "424e318e871b5c9cfd0dc51d2d2d70df8aae95ceef50013dea48b2ad4ca6d147": "ungefähr",
  "672556b12c138d82c3257e690310b43cdbdd369f67587481bb2a367db378f591": "das Pferd"
}