  "cd4f4e94197aec19c91e0229c619ccffa717f4cb77bfe2aab0c0305844edf4c6": "Das Besteck für den Hauptgang liegt innen.",
  "ff7fdeb2f5e2cca7ade9ce784298635a81f1501327f892544e47c173d3738e14": "betrunken",
  "4f070fa0b187d9110a2d448a36da7aad17e4c8d7b46bd289024949956568aea8": "Stäbchen dürfen nicht senkrecht im Reis stehen.",
  "02dfe4e3567f63f434fd81d3d412f70cebb7d0f5955e0e28dceb4d8ad82e72c1": "Sinnloses Nachwürzen ist unhöflich.",
